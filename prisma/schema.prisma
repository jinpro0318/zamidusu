// Prisma schema — Zamidusu MVP
// 개발/프로덕션 공통: Postgres (Supabase 또는 Neon).
// Vercel serverless는 SQLite 파일 쓰기를 못 하므로 Postgres 필수.
//
// DATABASE_URL 예: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// User — 인증 자체는 Supabase Auth가 담당 (세션/OAuth 토큰은 Supabase 관리).
// 이 테이블은 비즈니스 데이터의 외래키 기준점. id = Supabase user.id (또는 guest_*)
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  charts          Chart[]
  subscriptions   Subscription[]
  payments        Payment[]
  conversations   AiConversation[]
  compatibilities Compatibility[]  @relation("CompatibilityOwner")
  aiDailyUsages   AiDailyUsage[]
  feedbacks       Feedback[]
  purchases       Purchase[]
}

// ============================================================
// Feedback — 고객센터(의견 보내기) 접수 내역.
// 비로그인/게스트도 보낼 수 있으므로 userId는 nullable.
// ============================================================

model Feedback {
  id         String   @id @default(cuid())
  type       String   // "문의" | "버그 신고" | "기능 제안" | "기타"
  content    String
  replyEmail String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// Domain
// ============================================================

model Chart {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 본명/별칭
  subjectName String?
  gender      String  // "MALE" | "FEMALE"

  // 출생 정보 (검색·재계산용 분해 저장)
  birthCalendar String  // "SOLAR" | "LUNAR"
  birthYear     Int
  birthMonth    Int
  birthDay      Int
  birthHour     Int     // 0-23
  birthMinute   Int     @default(0)
  isLeapMonth   Boolean @default(false)
  timezone      String  @default("Asia/Seoul")

  // iztro 산출물 (JSON 직렬화 — SQLite는 String, Postgres는 Json으로 마이그레이션 가능)
  payload      String
  iztroVersion String

  // 공유
  shareToken    String? @unique
  shareEnabled  Boolean @default(false)

  // 프리미엄 게이팅
  isPremiumUnlocked Boolean @default(false)

  // 출생 시간 불확실(모름/추정) — 해석 상단 "참고용" 배지 표시용
  timeUncertain Boolean @default(false)
  // 저장 명반 분류 — 본인/가족/친구·지인/연인/기타
  relation      String  @default("본인")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations    AiConversation[]
  palaceReadings   PalaceReading[]
  deepReadings     DeepReading[]
  purchases        Purchase[]
  compatibilitiesA Compatibility[]  @relation("CompatibilityA")
  compatibilitiesB Compatibility[]  @relation("CompatibilityB")

  @@index([userId, createdAt])
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan             String   // "FREE" | "PREMIUM" | "PRO"
  status           String   // "ACTIVE" | "CANCELED" | "PAST_DUE" | "TRIALING"
  tossBillingKey   String?
  currentPeriodEnd DateTime?
  canceledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId    String  @unique
  paymentKey String? @unique
  amount     Int
  currency   String  @default("KRW")
  status     String  // "READY" | "DONE" | "CANCELED" | "FAILED" | "PARTIAL_CANCELED"

  productType String  // "PREMIUM_INTERPRETATION" | "SUBSCRIPTION" | "COMPATIBILITY"
  productRef  String?
  rawResponse String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AiConversation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chartId String
  chart   Chart  @relation(fields: [chartId], references: [id], onDelete: Cascade)

  messages   String  // JSON: [{role, content, createdAt}, ...]
  model      String
  tokenUsage Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, chartId])
}

// chart 1개 단위 "12궁 전체 상세풀이" 단건 구매.
// 1단계: 무통장입금(method=BANK_TRANSFER) + 관리자 수동 입금확인(status PENDING→PAID).
// 추후 PG 자동결제로 전환 시 method에 "TOSS" 등 추가(스키마 확장만으로 대응).
model Purchase {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chartId String
  chart   Chart  @relation(fields: [chartId], references: [id], onDelete: Cascade)

  amount        Int       @default(890)
  method        String    @default("BANK_TRANSFER") // "BANK_TRANSFER" | (추후) "TOSS" ...
  depositorName String? // 입금자명 (무통장입금 대조용)
  status        String    @default("PENDING") // "PENDING"=입금대기 | "PAID"=입금확인 | "CANCELLED"
  paidAt        DateTime? // 관리자가 입금확인한 시각
  createdAt     DateTime  @default(now())

  @@unique([userId, chartId]) // 같은 명반 중복 구매 방지
  @@index([status, createdAt]) // 관리자 "입금대기" 목록 조회용
}

// 궁별 "초기 풀이" 캐시 — 동일 (chartId, 궁) 재방문 시 LLM 재호출 없이 즉시 반환.
// 키에 modelVersion(실제 모델 id)·promptVersion(PROMPT_VERSION)을 포함해,
// 모델/프롬프트가 바뀌면 키가 달라져 새 캐시가 생성되고 옛 캐시는 더 이상 조회되지 않는다(stale 방지).
// 초기 4섹션 풀이에만 저장하며, 후속 자유질문은 캐시 대상이 아니다.
model PalaceReading {
  id      String @id @default(cuid())
  chartId String
  chart   Chart  @relation(fields: [chartId], references: [id], onDelete: Cascade)

  palaceKey     String // 예: 命宮
  modelVersion  String // 실제 모델 id, 예: "gemini-2.5-flash-lite"
  promptVersion String // PROMPT_VERSION, 예: "v1"
  content       String // 생성된 4섹션 풀이 원문(용어 마킹 포함)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chartId, palaceKey, modelVersion, promptVersion])
  @@index([chartId, palaceKey])
}

// 깊은풀이(궁 가로지르는 종합) 캐시. PalaceReading과 동일 캐시 패턴이며 키가 palaceKey→section.
// section: 깊은풀이 섹션 키. 생성부에서 "overview"|"interaction"|"timeline"|"summary"
//          (또는 합본 "all") 중 무엇으로 저장할지 확정. 모델은 어느 쪽도 수용.
model DeepReading {
  id      String @id @default(cuid())
  chartId String
  chart   Chart  @relation(fields: [chartId], references: [id], onDelete: Cascade)

  section       String
  modelVersion  String // 실제 모델 id, 예: "gemini-2.5-flash-lite"
  promptVersion String // PROMPT_VERSION, 예: "v1"
  content       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chartId, section, modelVersion, promptVersion])
  @@index([chartId, section])
}

// AI 일일 사용량 — 플랜별 일일 턴 한도를 정확히 집계 (추정치 X).
// date는 KST 기준 "YYYY-MM-DD" 문자열. upsert increment로 원자적 카운트.
model AiDailyUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date  String // "YYYY-MM-DD" (Asia/Seoul 기준)
  turns Int    @default(0)

  @@unique([userId, date])
}

model Compatibility {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("CompatibilityOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  chartAId String
  chartA   Chart  @relation("CompatibilityA", fields: [chartAId], references: [id])
  chartBId String
  chartB   Chart  @relation("CompatibilityB", fields: [chartBId], references: [id])

  score  Int
  detail String  // JSON

  createdAt DateTime @default(now())

  @@unique([chartAId, chartBId])
  @@index([ownerId])
}
