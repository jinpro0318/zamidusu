// Prisma schema — Zamidusu MVP
// 개발/프로덕션 공통: Postgres (Supabase 또는 Neon).
// Vercel serverless는 SQLite 파일 쓰기를 못 하므로 Postgres 필수.
//
// DATABASE_URL 예: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// User — 인증 자체는 Supabase Auth가 담당 (세션/OAuth 토큰은 Supabase 관리).
// 이 테이블은 비즈니스 데이터의 외래키 기준점. id = Supabase user.id (또는 guest_*)
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  charts          Chart[]
  subscriptions   Subscription[]
  payments        Payment[]
  conversations   AiConversation[]
  compatibilities Compatibility[]  @relation("CompatibilityOwner")
  aiDailyUsages   AiDailyUsage[]
}

// ============================================================
// Domain
// ============================================================

model Chart {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 본명/별칭
  subjectName String?
  gender      String  // "MALE" | "FEMALE"

  // 출생 정보 (검색·재계산용 분해 저장)
  birthCalendar String  // "SOLAR" | "LUNAR"
  birthYear     Int
  birthMonth    Int
  birthDay      Int
  birthHour     Int     // 0-23
  birthMinute   Int     @default(0)
  isLeapMonth   Boolean @default(false)
  timezone      String  @default("Asia/Seoul")

  // iztro 산출물 (JSON 직렬화 — SQLite는 String, Postgres는 Json으로 마이그레이션 가능)
  payload      String
  iztroVersion String

  // 공유
  shareToken    String? @unique
  shareEnabled  Boolean @default(false)

  // 프리미엄 게이팅
  isPremiumUnlocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations    AiConversation[]
  compatibilitiesA Compatibility[]  @relation("CompatibilityA")
  compatibilitiesB Compatibility[]  @relation("CompatibilityB")

  @@index([userId, createdAt])
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan             String   // "FREE" | "PREMIUM" | "PRO"
  status           String   // "ACTIVE" | "CANCELED" | "PAST_DUE" | "TRIALING"
  tossBillingKey   String?
  currentPeriodEnd DateTime?
  canceledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId    String  @unique
  paymentKey String? @unique
  amount     Int
  currency   String  @default("KRW")
  status     String  // "READY" | "DONE" | "CANCELED" | "FAILED" | "PARTIAL_CANCELED"

  productType String  // "PREMIUM_INTERPRETATION" | "SUBSCRIPTION" | "COMPATIBILITY"
  productRef  String?
  rawResponse String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AiConversation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chartId String
  chart   Chart  @relation(fields: [chartId], references: [id], onDelete: Cascade)

  messages   String  // JSON: [{role, content, createdAt}, ...]
  model      String
  tokenUsage Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, chartId])
}

// AI 일일 사용량 — 플랜별 일일 턴 한도를 정확히 집계 (추정치 X).
// date는 KST 기준 "YYYY-MM-DD" 문자열. upsert increment로 원자적 카운트.
model AiDailyUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date  String // "YYYY-MM-DD" (Asia/Seoul 기준)
  turns Int    @default(0)

  @@unique([userId, date])
}

model Compatibility {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("CompatibilityOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  chartAId String
  chartA   Chart  @relation("CompatibilityA", fields: [chartAId], references: [id])
  chartBId String
  chartB   Chart  @relation("CompatibilityB", fields: [chartBId], references: [id])

  score  Int
  detail String  // JSON

  createdAt DateTime @default(now())

  @@unique([chartAId, chartBId])
  @@index([ownerId])
}
