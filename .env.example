# === Database (Postgres / Supabase) ===
# Supabase: Dashboard → Connect → ORM → Prisma 탭 또는 Project Settings → Database
#
# DATABASE_URL: 런타임용 — Transaction pooler (포트 6543) + pgbouncer 파라미터 필수
#   - ?pgbouncer=true       Prisma의 prepared statement 캐시 비활성 (PgBouncer 트랜잭션 모드 호환, 42P05 방지)
#   - &connection_limit=1   서버리스 인스턴스당 1 커넥션
#   예) postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=""
#
# DIRECT_URL: prisma migrate / db push 전용 — Direct connection (포트 5432). pgbouncer 파라미터 붙이지 말 것.
#   예) postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=""

# === Site ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SHARE_TOKEN_SECRET="dev-share-token-secret"

# === Supabase Auth ===
# https://supabase.com/dashboard → 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# === Google Gemini AI ===
# https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# === Kakao Share JS SDK (선택) ===
# https://developers.kakao.com → JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY=""
